# Normalize line endings across the repository
* text=auto

# Enforce LF for source and config files
.gitattributes text eol=lf
.gitignore text eol=lf
VERSION text eol=lf
*.c text eol=lf
*.h text eol=lf
*.cpp text eol=lf
*.ino text eol=lf
*.hpp text eol=lf
*.cc text eol=lf
*.py text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.ini text eol=lf
*.props text eol=lf
*.sln text eol=lf
*.vcxproj text eol=lf
*.filters text eol=lf
*.rc text eol=lf
*.sh text eol=lf

# Windows scripts keep CRLF
*.ps1 text eol=crlf
*.bat text eol=crlf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.bmp binary
*.ico binary
*.zip binary
*.gz binary
*.bz2 binary
*.7z binary
*.pdf binary
*.stl binary
*.a binary
*.o binary
*.obj binary
