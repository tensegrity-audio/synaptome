{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Synaptome Layer Asset",
  "description": "Permissive G0 schema for layer assets consumed by LayerLibrary.",
  "type": "object",
  "required": ["id", "label", "category", "type"],
  "additionalProperties": true,
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "label": { "type": "string", "minLength": 1 },
    "category": { "type": "string", "minLength": 1 },
    "type": { "type": "string", "minLength": 1 },
    "registryPrefix": { "type": "string" },
    "description": { "type": "string" },
    "opacity": {
      "type": "number",
      "minimum": 0
    },
    "defaults": {
      "type": "object",
      "additionalProperties": true
    },
    "coverage": { "$ref": "#/definitions/coverage" },
    "hudWidget": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "definitions": {
    "coverage": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "mode": { "type": "string" },
        "columns": {
          "type": "integer",
          "minimum": 0
        }
      }
    }
  }
}
