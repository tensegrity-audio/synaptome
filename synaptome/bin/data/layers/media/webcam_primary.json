{
    "id": "media.webcam.primary",
    "label": "Webcam (Primary)",
    "category": "Media",
    "type": "media.webcam",
    "registryPrefix": "media.webcam.primary",
    "opacity": 1.0,
    "defaults": {
        "deviceName": "Integrated",
