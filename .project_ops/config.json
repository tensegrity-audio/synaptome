{
  "$schema": "https://tensegrity-audio.github.io/project_ops/schemas/v0.1.2/project_config.schema.json",
  "project": {
    "id": "synaptome",
    "name": "Synaptome",
    "role": "public-runtime",
    "description": "Public openFrameworks runtime for live modular visuals, operator controls, and projection output."
  },
  "paths": {
    "roadmap": "docs/project_ops/roadmap.md",
    "inProgress": "docs/project_ops/in_progress",
    "completed": "docs/project_ops/completed",
    "reports": "docs/project_ops/reports",
    "changelog": "docs/project_ops/reports/changelog.md",
    "governance": "docs/project_ops/governance",
    "requestTemplate": "docs/project_ops/in_progress/_REQUEST_TEMPLATE.md",
    "projectOpsContract": "docs/project_ops/README.md"
  },
  "scopeLabels": [
    "runtime",
    "contracts",
    "docs",
    "release",
    "tests",
    "governance"
  ],
  "requiredDocs": [
    "README.md",
    "LICENSE",
    "THIRD_PARTY_NOTICES.md",
    "VERSION",
    "docs/contributing.md",
    "docs/release_policy.md",
    "docs/build_env.md",
    "docs/dev_playbook.md",
    "docs/project_ops/README.md",
    "docs/project_ops/roadmap.md",
    "docs/project_ops/in_progress/_REQUEST_TEMPLATE.md",
    "docs/project_ops/reports/changelog.md",
    "docs/project_ops/governance/README.md",
    "docs/project_ops/completed/README.md",
    "docs/architecture/synaptome_system_architecture.md",
    "docs/architecture/synaptome_subsystem_anatomy.md",
    "docs/architecture/synaptome_external_contracts.md",
    "docs/contracts/README.md"
  ],
  "privacy": {
    "defaultVisibility": "public",
    "publicExamplesRequireSanitization": true,
    "privateHistoryPaths": [
      ".local/**",
      "docs/private/**",
      "synaptome/bin/data/local/**",
      "synaptome/bin/data/config/private/**"
    ]
  },
  "validation": {
    "requireChangelog": true,
    "requireRoadmapParity": true,
    "allowEmptyRoadmap": true,
    "dryRunByDefault": true,
    "commands": [
      {
        "name": "project-ops-adapter",
        "command": "python ../project_ops/tools/project_ops_audit.py --repo .",
        "required": true,
        "description": "Check Synaptome can consume the reusable Project Ops adapter from the external Project Ops repo."
      },
      {
        "name": "project-ops-compatibility-request",
        "command": "python ../project_ops/tools/project_ops_request_audit.py --repo . --request-id project_ops_compatibility",
        "required": true,
        "description": "Check the Synaptome Project Ops compatibility request remains synchronized with its roadmap and changelog."
      },
      {
        "name": "manifest",
        "command": "python tools/validate_synaptome_extraction_manifest.py --check --strict-review",
        "required": true,
        "description": "Check public extraction boundaries."
      },
      {
        "name": "release-metadata",
        "command": "python tools/validate_release_metadata.py",
        "required": true,
        "description": "Check Synaptome version and release metadata."
      },
      {
        "name": "osc-route-patterns",
        "command": "python tools/validate_osc_route_patterns.py",
        "required": true,
        "description": "Check built-in OSC route glob patterns against mesh-style sample addresses."
      },
      {
        "name": "public-contracts",
        "command": "python tools/validate_configs.py --public-app",
        "required": true,
        "description": "Check public runtime contracts and fixtures."
      },
      {
        "name": "app-independence",
        "command": "python tools/check_app_independence.py",
        "required": true,
        "description": "Check that the public runtime does not depend on the umbrella workspace."
      }
    ]
  },
  "bootstrap": {
    "requiredFiles": [
      "README.md",
      "LICENSE",
      "docs/contributing.md",
      "docs/release_policy.md",
      "docs/project_ops/README.md",
      "docs/project_ops/roadmap.md",
      "docs/project_ops/in_progress/_REQUEST_TEMPLATE.md",
      "docs/project_ops/reports/changelog.md",
      "docs/project_ops/governance/README.md",
      ".project_ops/config.json"
    ],
    "recommendedFiles": [],
    "initialDirectories": [
      "docs/architecture",
      "docs/contracts",
      "docs/examples",
      "docs/project_ops/in_progress",
      "docs/project_ops/completed",
      "docs/project_ops/reports",
      "docs/project_ops/governance"
    ]
  },
  "adoption": {
    "mode": "manual-templates",
    "frameworkRepo": "https://github.com/tensegrity-audio/project_ops",
    "frameworkRepoName": "project_ops",
    "frameworkVersion": "v0.1.2",
    "frameworkProductName": "Project Ops",
    "pilotNotes": "Synaptome adopts Project Ops roadmap, changelog, governance, and request-template surfaces while keeping product architecture and validation evidence local to the public runtime repo."
  }
}
